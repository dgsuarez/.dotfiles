#!/bin/sh
# Editor wrapper: opens files in an existing nvim running in a sibling tmux pane.
# Falls back to a regular nvim if not in tmux or no nvim found in the current window.
# Waits for the buffer to be deleted (:bd) before exiting.

FILE="$1"

if [ -z "$FILE" ]; then
  exec nvim
fi

if [ -n "$TMUX" ]; then
  SESSION=$(tmux display-message -p '#S')
  SOCK="/tmp/nvim-${SESSION}.sock"

  # Check if there's an nvim process in a sibling pane of the current window
  MY_PANE=$(tmux display-message -p '#{pane_id}')

  NVIM_PANE=$(tmux list-panes -F '#{pane_id} #{pane_current_command}' \
    | grep -v "^${MY_PANE} " \
    | grep -m1 'nvim$' \
    | cut -d' ' -f1)

  # Clean up stale socket if no nvim is running
  if [ -z "$NVIM_PANE" ] && [ -S "$SOCK" ]; then
    rm -f "$SOCK"
  fi

  if [ -n "$NVIM_PANE" ] && [ -S "$SOCK" ]; then
    SIGNAL=$(mktemp /tmp/nvim-remote-edit.XXXXXX)
    rm "$SIGNAL"

    # Focus the nvim pane, then open the file and set up the signal
    tmux select-pane -t "$NVIM_PANE"

    nvim --server "$SOCK" --remote-expr \
      "execute('edit $FILE | autocmd BufDelete,BufUnload <buffer> silent! call writefile([], \"$SIGNAL\")')" >/dev/null 2>&1

    # Wait for the signal file
    while [ ! -f "$SIGNAL" ]; do
      sleep 0.2
    done

    rm -f "$SIGNAL"

    # Focus back to the claude pane
    tmux select-pane -t "$MY_PANE"
    exit 0
  fi
fi

exec nvim "$FILE"
